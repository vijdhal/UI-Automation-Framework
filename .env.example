# ─────────────────────────────────────────────────────────────────────────────
# Environment template — copy this file to .env.dev / .env.qa / .env.uat
# and fill in the real values. Never commit the filled-in files.
# In CI, these values are injected from GitHub Environment Secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Salesforce org URL
BASE_URL=https://your-org.my.salesforce.com

# Internal API (non-SF backend, if applicable)
API_URL=https://api.your-app.com

# Database
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# Salesforce REST API — Connected App credentials
# Setup: Salesforce → App Manager → New Connected App → Enable OAuth
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_AUTH_URL=https://login.salesforce.com/services/oauth2/token
SF_API_VERSION=v62.0

# Salesforce Data Cloud
SF_DC_API_VERSION=v1
